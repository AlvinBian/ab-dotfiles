---
title: 主流程 — pnpm run setup
description: 所有入口分支：--quick / 重入選單 / 完整安裝
links:
  - setup-status: 查看/調整配置
  - phase-execute: 安裝執行
  - feature-map: 功能選擇
---
flowchart TD
    Start(["pnpm run setup"]) --> OrigBackup["首次備份<br/>~/.ab-dotfiles-original/"]
    OrigBackup --> Splash["顯示版本 + 上次安裝資訊"]

    Splash --> QuickCheck{"--quick?"}
    QuickCheck -->|Yes| QSession{"有上次 session?"}
    QSession -->|No| QError["無歷史記錄，退出"]
    QSession -->|Yes| QLoad["載入 session repos/roles"]
    QLoad --> QEnv["環境檢查"] --> QAnalyze["phaseAnalyze"] --> QExec["phaseExecute"] --> QComp["phaseComplete"] --> End(["設定完成"])

    QuickCheck -->|No| AllCheck{"--all?"}
    AllCheck -->|Yes| FreshEntry
    AllCheck -->|No| PrevCheck{"有上次 session?"}
    PrevCheck -->|No| FreshEntry
    PrevCheck -->|Yes| Reentry{"重入選單"}

    Reentry -->|"重新安裝"| RLegacy["舊配置偵測"] --> RAnalyze["phaseAnalyze"] --> RExec["phaseExecute"] --> RComp["phaseComplete"] --> End
    Reentry -->|"調整設定"| AdjLegacy["舊配置偵測"] --> FreshEntry
    Reentry -->|"查看/調整配置"| StatusLink["→ setup-status"]
    Reentry -->|"查看上次報告"| Report["開啟報告"] --> End
    Reentry -->|ESC| Cancel(["已取消"])

    subgraph FreshEntry ["完整安裝流程"]
        F0["舊配置偵測清理"] --> F1["環境檢查<br/>brew nvm node pnpm gh claude"]
        F1 --> F2["功能選擇 multiselect"]
        F2 --> F3{"has Slack?"} -->|Yes| F3a["Slack 通知設定"] --> F4
        F3 -->|No| F4{"has Gmail?"} -->|Yes| F4a["Gmail 5-Tier 設定"] --> F5
        F4 -->|No| F5["外部服務設定摘要"]
        F5 --> Loop
    end

    subgraph Loop ["Phase Loop — 支持 BACK"]
        L1["Step 1/3 選擇倉庫"] --> L1a["interactiveRepoSelect"]
        L1a -->|ESC| Cancel
        L1a --> L2["角色分類 loop"]
        L2 -->|上一步| L1
        L2 -->|確認| L3["phaseAnalyze 自動分析"]
        L3 --> L4["Step 2/3 確認計畫"]
        L4 -->|上一步| L1
        L4 -->|確認| L5{"--dry-run?"}
        L5 -->|Yes| DryEnd(["顯示計畫 不執行"])
        L5 -->|No| L6["Step 3/3 phaseExecute"]
        L6 --> L7["phaseComplete"]
    end

    L7 --> End

    click StatusLink "#setup-status"
    click F2 "#feature-map"
    click F4a "#gmail-setup"
    click L1a "#repo-select"
    click L2 "#role-system"
    click L4 "#phase-plan"
    click L6 "#phase-execute"

    classDef decision fill:#d29922,color:#000
    classDef action fill:#1f6feb,color:#fff
    classDef success fill:#238636,color:#fff
    classDef error fill:#da3633,color:#fff

    class QuickCheck,AllCheck,PrevCheck,F3,F4,L5 decision
    class QLoad,QEnv,QAnalyze,QExec,QComp,RLegacy,RAnalyze,RExec,RComp action
    class End,DryEnd success
    class QError error
