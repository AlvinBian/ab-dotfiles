        EC3 --> ECT
        EC4 --> ECT
    end

    subgraph C4G ["Slack 通知"]
        C4["☑️ Slack"]
        C4 --> S1["Channel 模式
        搜尋/建立頻道"]
        C4 --> S2["DM 模式
        私發給自己"]
        C4 --> S3["關閉"]
        S1 --> ST["→ .env SLACK_NOTIFY_*
