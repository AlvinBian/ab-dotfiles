{
  "name": "ab-dotfiles",
  "version": "1.0.0",
  "description": "Alvin Bian 個人開發工具包：Claude Code 全域設定、KKday 開發規範、Kiro 工作區生成",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "install:claude":    "bash scripts/install-claude.sh",
    "install:zsh":       "bash scripts/setup-zsh.sh",
    "install:env":       "bash scripts/fix-env.sh",
    "install:all":       "pnpm run install:claude && pnpm run install:zsh",
    "build:plugin":      "bash scripts/build-plugin.sh",
    "workspace":         "bash scripts/generate-workspace.sh",
    "workspace:open":    "bash scripts/generate-workspace.sh && open \"$(dirname $(pwd))/$(basename $(dirname $(pwd))).code-workspace\"",
    "deploy":            "pnpm run install:claude && pnpm run build:plugin"
  }
}
