{
  "name": "ab-dotfiles",
  "version": "1.0.0",
  "description": "Alvin Bian 個人開發工具包：Claude Code 全域設定、KKday 開發規範、Kiro 工作區生成",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "setup":     "node bin/setup.mjs",
    "deploy":    "bash scripts/install-claude.sh && bash scripts/build-plugin.sh",
    "build":     "bash scripts/build-plugin.sh",
    "workspace": "bash scripts/generate-workspace.sh",
    "fix":       "bash zsh/fix-env.sh"
  },
  "devDependencies": {
    "@clack/prompts": "^0.9.1"
  }
}
