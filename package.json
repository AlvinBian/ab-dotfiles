{
  "name": "ab-dotfiles",
  "version": "1.0.0",
  "description": "開發環境統一管理工具 — Claude Code 配置、技術棧技能庫、zsh 模組、工作區生成",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "setup": "node bin/setup.mjs",
    "scan": "node bin/scan.mjs",
    "restore": "node bin/restore.mjs",
    "doctor": "node -e \"import('./lib/doctor.mjs').then(m => m.ensureEnvironment())\"",
    "workspace": "bash scripts/generate-workspace.sh"
  },
  "devDependencies": {
    "@clack/prompts": "^0.9.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4"
  }
}
