# ═══════════════════════════════════════════════════════════════
# ab-dotfiles 環境配置
# 複製為 .env 後修改：cp .env.template .env
# ═══════════════════════════════════════════════════════════════

# ── AI（Claude）──────────────────────────────────────────────
# API Key（選填，填了走 SDK 直連，不填走 Claude Code CLI）
ANTHROPIC_API_KEY=
# 預設模型（haiku / sonnet / opus）
AI_MODEL=haiku
# 推理強度（low / medium / high / max）
AI_EFFORT=low
# AI 呼叫超時（毫秒）
AI_TIMEOUT=60000
# AI 並發生成數
AI_CONCURRENCY=5
# Per-repo AI 分類（每個 repo 獨立分析，並行執行）
AI_REPO_MODEL=sonnet
AI_REPO_EFFORT=low
AI_REPO_TIMEOUT=60000
AI_REPO_CACHE=true
AI_REPO_MAX_CATEGORIES=10
AI_REPO_MAX_TECHS=30

# ── GitHub ───────────────────────────────────────────────────
# 預設掃描的 GitHub Organization
GITHUB_ORG=
# gh api 超時（毫秒）
GH_API_TIMEOUT=15000
# 每頁返回數量
GH_PER_PAGE=100
# 單個 repo 分析超時（毫秒）
GH_REPO_ANALYZE_TIMEOUT=30000
# search/commits 最大返回數
GH_COMMIT_SEARCH_LIMIT=100

# ── npm registry ─────────────────────────────────────────────
# npm registry 查詢超時（毫秒）
NPM_FETCH_TIMEOUT=5000
# 並行查詢批次大小
NPM_BATCH_SIZE=10

# ── ECC 外部來源 ─────────────────────────────────────────────
# 格式：name|repo|priority（多個用逗號分隔）
# 範例：everything-claude-code|affaan-m/everything-claude-code|10
ECC_SOURCES=everything-claude-code|affaan-m/everything-claude-code|10

# ── 掃描 ─────────────────────────────────────────────────────
# 遞迴掃描目錄最大深度
SCAN_DIR_MAX_DEPTH=1
# README 等文件截斷行數
DOC_TRUNCATE_LINES=100
# 倉庫描述截斷長度
DESC_MAX_LENGTH=40
# 最短 session 時長（秒），低於此不發完成通知（預設 5 分鐘）
CLAUDE_SLACK_MIN_SESSION_SECS=300

# ── 其他 ─────────────────────────────────────────────────────
# 備份保留次數
BACKUP_MAX_COUNT=10
# 進度條寬度（字元數）
PROGRESS_BAR_SIZE=26
