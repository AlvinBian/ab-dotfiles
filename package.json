{
  "name": "ab-dotfiles",
  "version": "1.0.0",
  "description": "Alvin Bian 個人開發工具包：Claude Code 全域設定、KKday 開發規範、Kiro 工作區生成",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "setup": "node bin/setup.mjs",
    "setup:all": "node bin/setup.mjs --all",
    "setup:claude": "node bin/setup.mjs --claude",
    "setup:zsh": "node bin/setup.mjs --zsh",
    "install:claude": "bash scripts/install-claude.sh",
    "install:zsh": "bash zsh/install.sh --all",
    "fix:env": "bash zsh/fix-env.sh",
    "build:plugin": "bash scripts/build-plugin.sh",
    "workspace": "bash scripts/generate-workspace.sh",
    "workspace:open": "bash scripts/generate-workspace.sh && open \"$(dirname $(pwd))/$(basename $(dirname $(pwd))).code-workspace\"",
    "deploy": "bash scripts/install-claude.sh && bash scripts/build-plugin.sh"
  },
  "devDependencies": {
    "@clack/prompts": "^0.9.1"
  }
}
