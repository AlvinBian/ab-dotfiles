---
flowchart TD
    Start([setupGmailFilters]) --> HasPrev{"session 有 scriptId?"}

    HasPrev -->|Yes| Keep{"保持不變？<br/>Script ID: xxx"}
    Keep -->|Yes| ReturnPrev([返回現有設定])
    Keep -->|"No（重新設定）"| Step1
    Keep -->|ESC| Null([返回 null])

    HasPrev -->|No| Step1

    subgraph Step1 ["Step 1: clasp 環境"]
        C1{"clasp 已安裝?"}
        C1 -->|"Yes"| C1ok["clasp 已安裝（/usr/local/bin/clasp）"]
        C1 -->|No| C2{"安裝？"}
        C2 -->|Yes| C3["npm install -g @google/clasp"]
        C3 -->|成功| C1ok
        C3 -->|失敗| Manual
        C2 -->|No| Manual["手動步驟<br/>1. npm i -g @google/clasp<br/>2. clasp login<br/>3. clasp create<br/>4. clasp push<br/>5. 執行 setupAndApply"]
    end

    C1ok --> Step2

    subgraph Step2 ["Step 2: Google 登入"]
        L1{"~/.clasprc.json 存在?"}
        L1 -->|"Yes"| L1ok["已偵測到登入狀態"]
        L1 -->|No| L2["clasp login（開啟瀏覽器授權）"]
        L2 -->|成功| L1ok
        L2 -->|失敗| Manual
    end

    L1ok --> Step3["複製 .gs + appsscript.json 到暫存目錄"]
    Step3 --> Step4

    subgraph Step4 ["Step 4: 建立/複用專案"]
        D1{"session 有 scriptId?"}
        D1 -->|"Yes 複用"| D2["寫入 .clasp.json → 直接推送更新"]
        D1 -->|"No 建新"| D3["clasp create<br/>--type standalone<br/>--title Gmail 5-Tier Filters"]

        D3 --> D3r{"成功?"}
        D3r -->|"API 未啟用"| D4["自動開啟設定頁面<br/>script.google.com/home/usersettings"]
        D4 --> D5["等用戶開啟 API → Enter"]
        D5 --> D6["重試 clasp create"]
        D6 --> D3r
        D3r -->|"成功"| D7["取得 Script ID"]
        D3r -->|"失敗 x3"| Manual
    end

    D2 --> Step5
    D7 --> Step5

    subgraph Step5 ["Step 5: 推送腳本"]
        P1["clasp push --force<br/>(async spinner 旋轉中)"]
        P1 -->|成功| P2["腳本推送完成"]
        P1 -->|失敗| Manual
    end

    P2 --> Step6

    subgraph Step6 ["Step 6: 引導執行"]
        G1["自動開啟 Apps Script 編輯器"]
        G1 --> G2["引導用戶：<br/>1. 選函式 setupAndApply<br/>2. 點擊 Run 執行<br/>3. 授權 Gmail API<br/>執行效果：<br/>deleteAllFilters（清舊）<br/>createLabelsIfNeeded（建標籤）<br/>buildRules x 17 條 filter<br/>applyToExisting（追溯分類）"]
    end

    G2 --> Result

    subgraph Result ["5-Tier 分級效果"]
        direction LR
        T0["Tier 0<br/>github/noise<br/>GitHub · CI · bot"]
        T1["Tier 1<br/>auto/skip<br/>Jira · Slack · SaaS"]
        T2["Tier 2<br/>auto/info<br/>公告 · 收據 · Figma"]
        T3["Tier 3<br/>auto/meeting<br/>行事曆邀請"]
        T4["Tier 4 priority<br/>action/required<br/>HR · 財務 · 緊急<br/>IMPORTANT + STARRED"]
    end

    Result --> Return(["返回 scriptId, scriptUrl"])

