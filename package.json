{
  "name": "ab-dotfiles",
  "version": "2.0.0",
  "description": "開發環境統一管理工具 — Claude Code 配置、技術棧技能庫、zsh 模組、工作區生成",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "setup": "node bin/setup.mjs",
    "scan": "node bin/scan.mjs",
    "restore": "node bin/restore.mjs",
    "restore-original": "node bin/restore-original.mjs",
    "backup-original": "node bin/backup-original.mjs",
    "doctor": "node -e \"import('./lib/doctor.mjs').then(m => m.ensureEnvironment())\"",
    "workspace": "bash scripts/generate-workspace.sh",
    "taxonomy:build": "node lib/taxonomy/build.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset version && git add -A && git commit -m 'chore: version packages' && git tag v$(node -p \"require('./package.json').version\") && git push --follow-tags"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "listr2": "^10.2.1",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4"
  }
}
